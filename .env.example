# ──────────────────────────────────────────────────────────────────────────────
# Convergence MVP — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────────

# ── Privy Auth ────────────────────────────────────────────────────────────────
# App ID: dashboard.privy.io → Settings → App ID
# NEXT_PUBLIC_ prefix makes this available in the browser bundle.
NEXT_PUBLIC_PRIVY_APP_ID=

# App Secret: dashboard.privy.io → Settings → App Secret
# Server-only — never expose in the browser.
PRIVY_APP_SECRET=

# ── Arbitrum (optional) ───────────────────────────────────────────────────────
# Arbitrum Sepolia RPC. Defaults to the public Offchain Labs endpoint.
# Replace with an Alchemy or Infura URL for production reliability.
# NEXT_PUBLIC_ required so the browser wallet provider can connect.
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ── Supabase — Community Discussion DB ───────────────────────────────────────
# The supabase-js REST API URL. Format: https://<project-ref>.supabase.co
# Find in: dashboard.supabase.com → Project → Settings → API → Project URL
#
# Note: this codebase uses supabase-js (REST/HTTP), not a direct Postgres connection.
# Connection pooling is handled by Supabase internally. No pooler URL needed here.
# If you add a direct pg/drizzle connection later, use the pooler URL instead.
SUPABASE_URL=

# Service Role key: dashboard.supabase.com → Project → Settings → API → service_role
# Server-only — never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Pinecone — Vector Store ───────────────────────────────────────────────────
# API key from app.pinecone.io → API Keys
PINECONE_API_KEY=

# Pinecone index name. Defaults to "convergence-mvp" if not set.
PINECONE_INDEX=convergence-mvp

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for embeddings (text-embedding-3-small) and answer generation (gpt-4o-mini).
OPENAI_API_KEY=

# ── Acceptance Pass NFT ───────────────────────────────────────────────────────
# ERC-1155 contract on Base mainnet (chain 8453).
# Server-side: used by the token gate to verify pass ownership.
ACCEPTANCE_PASS_CONTRACT_ADDRESS=0x9691107411afb05b81cfde537efc4a00b9b1bb69

# Client-side: used by PassOwnershipBadge component for explorer links.
# NEXT_PUBLIC_ prefix required for browser access.
NEXT_PUBLIC_ACCEPTANCE_PASS_CONTRACT=0x9691107411afb05b81cfde537efc4a00b9b1bb69

# Base RPC URL (optional). Defaults to https://mainnet.base.org
# Replace with Alchemy/Infura for reliability: https://base-mainnet.g.alchemy.com/v2/<KEY>
# BASE_RPC_URL=https://mainnet.base.org

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Wallet address that is granted admin access to /api/community/admin/* routes.
# Pass as Authorization: Bearer <wallet-address> to authenticate.
ADMIN_WALLET=

# ── Vercel Cron Auth ──────────────────────────────────────────────────────────
# Secret used to authenticate the /api/community/embed-posts cron endpoint.
# Vercel automatically sends: Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── Upstash Redis (optional — rate limiting) ──────────────────────────────────
# When set, all public API routes use Redis for per-IP/per-user rate limiting
# instead of in-memory (required for multi-process / Vercel serverless).
# In-memory is used automatically when these are absent (single-process only).
# Create at console.upstash.com → Redis → REST API.
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ── Internal API Token (rate limit bypass) ────────────────────────────────────
# Requests that include the header `X-Internal-Token: <value>` skip all rate
# limits. Use for agent-to-agent calls, cron jobs, and server-side health checks.
# Generate: openssl rand -hex 32
# INTERNAL_API_TOKEN=

# ── Resend (email / subscriber export + deploy notifications) ─────────────────
# Required for pnpm export:subscribers (emergency subscriber CSV export).
# Also used by POST /api/webhooks/deploy to send deploy success/failure emails.
# API key: resend.com → API Keys
# RESEND_API_KEY=re_...
# Audience ID: resend.com → Audiences → <audience> → copy ID
# RESEND_AUDIENCE_ID=

# ── Resend webhook signature verification ─────────────────────────────────────
# Secret for validating inbound Resend email analytics webhooks.
# Find in: resend.com → Webhooks → <webhook> → Signing Secret
# RESEND_WEBHOOK_SECRET=whsec_...

# ── Deploy webhook notifications ──────────────────────────────────────────────
# Secret for validating x-vercel-signature on Vercel deployment webhooks.
# Generate: openssl rand -hex 32  (then set the same value in Vercel → Webhooks)
# VERCEL_WEBHOOK_SECRET=

# Admin email address for deployment notifications (success/failure).
# Falls back to SLACK_WEBHOOK_URL if that is set instead.
# ADMIN_EMAIL=nick@example.com

# Slack incoming webhook URL (optional — overrides email if set).
# Create at api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Sentry — Error monitoring ─────────────────────────────────────────────────
# DSN from sentry.io → Project → Settings → Client Keys
# Used by both server and client Sentry configs.
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to include community posts in the Q&A RAG pipeline.
# When enabled, top-voted community posts are surfaced alongside archive answers.
# Default: false (community RAG is opt-in)
ENABLE_COMMUNITY_RAG=false
